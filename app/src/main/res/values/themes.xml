<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Chat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/toolbar</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/primary_text</item>
        <item name="colorSurfaceVariant">@color/secondary_surface</item>
        <item name="colorOnSurfaceVariant">@color/secondary_text</item>
    </style>

    <!-- Rounded Corner Styles -->
    <style name="ShapeAppearance.Huddle.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Huddle.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">20dp</item>
    </style>

    <style name="ShapeAppearance.Huddle.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Message Bubble Styles -->
    <style name="SentBubbleStyle">
        <item name="android:background">@drawable/bg_sent_bubble</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="ReceivedBubbleStyle">
        <item name="android:background">@drawable/bg_received_bubble</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="Widget.Huddle.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.Huddle.Small</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.Huddle.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

</resources>
